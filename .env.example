# The site runs fully without these. When unset, form submissions are validated and
# logged to the server console instead of stored/emailed (handy for local dev).

# Supabase (lead storage) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email notifications) — https://resend.com
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=owner@example.com

# Cloudflare Turnstile (form spam protection) — optional
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
